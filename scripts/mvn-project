#!/usr/bin/env bash
set -euo pipefail

# JDK 17+ 才能编译 Spring Boot 4.x + Java 25 target
export JAVA_HOME="${JAVA_HOME:-/opt/homebrew/Cellar/openjdk@17/17.0.16/libexec/openjdk.jdk/Contents/Home}"
export PATH="$JAVA_HOME/bin:$PATH"

MAVEN_HOME="${MAVEN_HOME:-$HOME/Code/tools/MAVEN/apache-maven-3.9.2}"
MAVEN_SETTINGS="${MAVEN_SETTINGS:-$MAVEN_HOME/conf/settings.xml}"
MAVEN_REPO_LOCAL="${MAVEN_REPO_LOCAL:-$HOME/Code/tools/MAVEN/repository}"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
cd "$PROJECT_DIR"

exec "$MAVEN_HOME/bin/mvn" \
  -s "$MAVEN_SETTINGS" \
  -Dmaven.repo.local="$MAVEN_REPO_LOCAL" \
  "$@"
