# AnalyticsHub backend environment example.
# Copy this file to /etc/analyticshub/analyticshub.env on the server.
# 所有 replace-with-* 都必须替换；check-app.sh 会拦截这些 placeholder。
#
# Deployment model:
# - One server runs multiple backend apps.
# - AnalyticsHub is mounted by nginx at /analyticshub/**.
# - This env only configures the Java backend process itself.

# Runtime profile. Keep prod for server deployment.
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=3001

# System PostgreSQL database.
# This database only stores AnalyticsHub project metadata, especially
# analytics.analytics_projects. Each tracked business project still uses its own target
# database configured through the admin project table.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=analytics
DB_SCHEMA=analytics
DB_USER=analytic
DB_PASSWORD=replace-with-database-password

# Admin API token for /api/admin/** and actuator-sensitive endpoints.
# setup-app.sh generates a strong random token on first install.
ADMIN_TOKEN=replace-with-at-least-32-random-characters

# Mail is optional. Enable it when security alerts or privacy request emails
# should be sent. ALERT_EMAIL is the operator mailbox.
MAIL_ENABLED=false
MAIL_HOST=smtpdm.aliyun.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
ALERT_EMAIL=

# Optional admin 2FA.
APP_SECURITY_2FA_ENABLED=false
APP_SECURITY_2FA_SECRET=

# HTTP/API operational limits.
APP_CORS_ALLOWED_ORIGINS=*
APP_RATE_LIMIT_REQUESTS=100
APP_RATE_LIMIT_WINDOW_MS=60000
