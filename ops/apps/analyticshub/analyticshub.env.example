# AnalyticsHub backend environment example.
# AnalyticsHub 只保留单实例，不再拆 prod/test 槽位。
# 所有 replace-with-* 都必须替换；check-app.sh 会拦截这些 placeholder。

SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=3001
LOG_PATH=/var/log/analyticshub
LOG_FILE=analyticshub
LOG_MAX_FILE_SIZE=50MB
LOG_MAX_HISTORY=14
LOG_TOTAL_SIZE_CAP=512MB

# AnalyticsHub 自身系统库。
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=analytics
DB_SCHEMA=analytics
DB_USER=analytic
DB_PASSWORD=replace-with-database-password

# 管理接口 token。首次 setup 会自动生成强随机值。
ADMIN_TOKEN=replace-with-at-least-32-random-characters

# 邮件告警，可选。test/prod 日志会脱敏这些字段。
MAIL_ENABLED=false
MAIL_HOST=smtpdm.aliyun.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
ALERT_EMAIL=

APP_SECURITY_2FA_ENABLED=false
APP_SECURITY_2FA_SECRET=

APP_CORS_ALLOWED_ORIGINS=*
APP_RATE_LIMIT_REQUESTS=100
APP_RATE_LIMIT_WINDOW_MS=60000
