# ============================================================
# AnalyticsHub - 开发环境配置
# 用于本地开发测试，包含默认值
# ============================================================

# 数据库配置（开发环境默认值）
DB_HOST=localhost
DB_PORT=5432
DB_NAME=analytics
DB_SCHEMA=analytics
DB_USER=analytic
DB_PASSWORD=replace-with-local-analytic-password

# 管理端 Token（本地开发也建议换成自己的随机值）
ADMIN_TOKEN=replace-with-local-admin-token

# Spring 配置
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=3001

# 开发调试配置
LOGGING_LEVEL_COM_GITHUB_ANALYTICSHUB=DEBUG

# ============================================================
# 安全告警与邮件推送（SMTP）
# ============================================================
MAIL_ENABLED=false
MAIL_HOST=smtpdm.aliyun.com
MAIL_PORT=465
MAIL_USERNAME=notify@example.com
MAIL_PASSWORD=your_smtp_password_here
ALERT_EMAIL=your_receive_email@example.com

# ============================================================
# 双因素认证 (2FA) - TOTP
# ============================================================
APP_SECURITY_2FA_ENABLED=false
APP_SECURITY_2FA_SECRET=

# CORS 配置（开发时允许所有来源）
APP_CORS_ALLOWED_ORIGINS=*

# 速率限制（开发时可调高）
APP_RATE_LIMIT_REQUESTS=1000
APP_RATE_LIMIT_WINDOW_MS=60000
